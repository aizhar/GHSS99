# ----------------------------------------------------------------------------
# GHSS99 Class Fellows Portal — Environment Variables
# Copy this file to ".env" and fill in real values for local development.
# On Vercel, add each of these in: Project Settings -> Environment Variables.
# NEVER commit your real .env file.
# ----------------------------------------------------------------------------

# --- Server ---
# Port used for local development only (Vercel sets this automatically).
PORT=3000

# --- MongoDB Atlas ---
# Get this from MongoDB Atlas -> Connect -> Drivers. Remember to URL-encode
# any special characters in your password and to set the database name.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ghss99?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string

# --- JWT (admin auth) ---
# A long, random secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
# How long an admin login stays valid.
JWT_EXPIRES_IN=8h

# --- Admin account (single admin, Option A) ---
ADMIN_USERNAME=admin
# Preferred: store a bcrypt HASH of the password (run `npm run hash-password`).
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
# Optional fallback ONLY for quick local testing if no hash is set.
# Leave blank in production.
ADMIN_PASSWORD=

# --- Cloudinary (image uploads) ---
# From your Cloudinary Dashboard.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Folder inside Cloudinary where profile photos are stored.
CLOUDINARY_FOLDER=ghss99-profiles
